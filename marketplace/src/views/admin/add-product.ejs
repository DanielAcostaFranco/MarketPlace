<%- include('../partials/header') %>

    <main class="admin-dashboard">
        <h1>Admin Dashboard</h1>
        <div class="admin-nav">
            <a href="/admin/products" class="btn">Products</a>
            <a href="/admin/orders" class="btn">Orders</a>
            <a href="/admin/users" class="btn">Users</a>
            <a href="/admin/contact" class="btn">Contact</a>
        </div>

        <h2>Add New Product</h2>
        <form action="/admin/products/new" method="POST" class="admin-form">
            <div class="form-group">
                <label for="name">Product Name:</label>
                <input type="text" id="name" name="name" required>
            </div>
            <div class="form-group">
                <label for="description">Description:</label>
                <textarea id="description" name="description" required></textarea>
            </div>
            <div class="form-group">
                <label for="price">Price:</label>
                <input type="number" id="price" name="price" step="0.01" required>
            </div>
            <div class="form-group">
                <label for="category">Category:</label>
                <input type="text" id="category" name="category" required>
            </div>
            <div class="form-group">
                <label for="image_url">Image URL:</label>
                <input type="text" id="image_url" name="image_url" required>
            </div>
            <button type="submit" class="btn">Add Product</button>
        </form>

    </main>

    <%- include('../partials/footer') %>