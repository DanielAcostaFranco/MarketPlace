<%- include('../partials/header') %>

    <main class="admin-dashboard">
        <h1>Admin Dashboard</h1>
        <div class="admin-nav">
            <a href="/admin/products" class="btn">Products</a>
            <a href="/admin/orders" class="btn">Orders</a>
            <a href="/admin/users" class="btn">Users</a>
        </div>

        <h2>Users</h2>
        <table class="admin-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Actions</th>
                    <th>Delete</th>
                </tr>
            </thead>
            <tbody>
                <% users.forEach(user=> { %>
                    <tr>
                        <td>
                            <%= user.id %>
                        </td>
                        <td>
                            <%= user.username %>
                        </td>
                        <td>
                            <%= user.email %>
                        </td>
                        <td>
                            <%= user.role %>
                        </td>
                        <td>
                            <form action="/admin/users/<%= user.id %>/role" method="POST" style="display:inline;">
                                <select name="role">
                                    <option value="buyer" <%=user.role==='buyer' ? 'selected' : '' %>>Buyer</option>
                                    <option value="moderator" <%=user.role==='moderator' ? 'selected' : '' %>>Moderator</option>
                                    <option value="admin" <%=user.role==='admin' ? 'selected' : '' %>>Admin</option>
                                </select>
                                <button type="submit" class="btn">Update</button>
                            </form>
                        </td>
                        <td>
                            <form action="/admin/users/<%= user.id %>/delete" method="POST" style="display:inline;">
                                <button type="submit" class="btn">Delete</button>
                            </form>
                        </td>
                    </tr>
                    <% }) %>
            </tbody>
        </table>

    </main>

    <%- include('../partials/footer') %>