<%- include('../partials/header') %>

    <main class="admin-dashboard">
        <h1>Admin Dashboard</h1>
        <div class="admin-nav">
            <a href="/admin/products" class="btn">Products</a>
            <a href="/admin/orders" class="btn">Orders</a>
            <a href="/admin/users" class="btn">Users</a>
        </div>

        <h2>Users</h2>
        <table class="admin-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Role</th>
                </tr>
            </thead>
            <tbody>
                <% users.forEach(user=> { %>
                    <tr>
                        <td>
                            <%= user.id %>
                        </td>
                        <td>
                            <%= user.name %>
                        </td>
                        <td>
                            <%= user.email %>
                        </td>
                        <td>
                            <%= user.role %>
                        </td>
                    </tr>
                    <% }) %>
            </tbody>

    </main>

    <%- include('../partials/footer') %>