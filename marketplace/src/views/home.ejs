<%- include('./partials/header') %>

    <main class="home">

        <!-- Hero Section -->
        <section class="hero">
            <div class="hero-content">
                <h1>Welcome to Damazon</h1>
                <p>Find the best tech products at the best price.</p>
                <a href="/products" class="btn-hero">Shop Now</a>
            </div>
        </section>

        <!-- Featured Products -->
        <section class="featured">
            <h2>Featured Products</h2>
            <div class="featured-grid">
                <div class="featured-card">
                    <img src="/images/products/smartwatch.jpg" alt="Smartwatch">
                    <p>Smartwatch</p>
                </div>
                <div class="featured-card">
                    <img src="/images/products/gaming-console.jpg" alt="Gaming Console">
                    <p>Gaming Console</p>
                </div>
                <div class="featured-card">
                    <img src="/images/products/drone-mini.jpg" alt="Mini Drone">
                    <p>Mini Drone</p>
                </div>
            </div>
        </section>

    </main>

    <%- include('./partials/footer') %>n