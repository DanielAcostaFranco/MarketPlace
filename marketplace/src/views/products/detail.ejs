<link rel="stylesheet" href="/css/detail.css">
<%- include ('../partials/header') %>

    <main>
        <div class="product-detail">
            <img src="<%= product.image_url %>" alt="<%= product.name %>">
            <div class="product-info">
                <h1>
                    <%= product.name %>
                </h1>
                <p>
                    <%= product.description %>
                </p>
                <p class="price">$<%= parseFloat(product.price).toFixed(2) %>
                </p>
                <% if (!isLoggedIn) { %>
                    <a href="/login-required" class="btn">Add to Cart</a>
                <% } else if (user.role !== 'admin') { %>
                    <form action="/cart/add" method="POST">
                        <input type="hidden" name="product_id" value="<%= product.id %>">
                        <button type="submit" class="btn">Add to Cart</button>
                    </form>
                <% } %>
            </div>
        </div>

        <div class="reviews">
            <h2>Customer Reviews</h2>
            <% if (reviews.length===0) { %>
                <p>No reviews yet. Be the first to review this product!</p>
            <% } else { %>
                <% reviews.forEach(review=> { %>
                    <div class="review">
                        <p><strong><%= review.username %></strong> - Rating: <%= review.rating %>/5</p>
                        <p><%= review.comment %></p>
                        <% if (isLoggedIn && user.id === review.user_id) { %>
                            <a href="/reviews/<%= review.id %>/edit" class="btn">Edit</a>
                        <% } %>
                        <% if (isLoggedIn && (user.id === review.user_id || user.role==='admin' || user.role==='moderator')) { %>
                            <form action="/reviews/<%= review.id %>/delete" method="POST" style="display:inline;">
                                <input type="hidden" name="productId" value="<%= product.id %>">
                                <button type="submit" class="btn delete">Delete</button>
                            </form>
                        <% } %>
                    </div>
                <% }) %>
            <% } %>

            <% if (isLoggedIn) { %>
                <form action="/products/<%= product.id %>/review" method="POST" class="review-form">
                    <label>Rating (1-5)</label>
                    <input type="number" name="rating" min="1" max="5" required>
                    <label>Comment</label>
                    <textarea name="comment" required></textarea>
                    <button type="submit" class="btn">Submit Review</button>
                </form>
            <% } %>
        </div>
    </main>

    <%- include('../partials/footer') %>
