<%- include('../partials/header') %>

<main>
    <h1>Edit Review</h1>
    <form action="/reviews/<%= review.id %>/edit" method="POST" class="admin-form">
        <input type="hidden" name="productId" value="<%= review.product_id %>">
        <div class="form-group">
            <label for="rating">Rating (1-5)</label>
            <input type="number" id="rating" name="rating" min="1" max="5" value="<%= review.rating %>" required>
        </div>
        <div class="form-group">
            <label for="comment">Comment</label>
            <textarea id="comment" name="comment" required><%= review.comment %></textarea>
        </div>
        <button type="submit" class="btn">Update Review</button>
        <a href="/products/<%= review.product_id %>" class="btn delete" style="margin-left:8px;">Cancel</a>
    </form>
</main>

<%- include('../partials/footer') %>
